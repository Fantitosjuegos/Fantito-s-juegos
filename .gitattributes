# Auto detect text files and perform LF normalization
* text=auto

# Force Unix line endings for these files
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.json text eol=lf
*.css text eol=lf
*.html text eol=lf
*.md text eol=lf

# Force Unix line endings for Android/Gradle files
*.gradle text eol=lf
*.java text eol=lf
*.xml text eol=lf
gradlew text eol=lf

# Binary files - no line ending conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.lockb binary